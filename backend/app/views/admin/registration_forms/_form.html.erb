<%# Locals: registration_form (real or unsaved), ticket_categories (Array<TicketCategory>, all of
    @event's own — not just the ones already assigned to this form). Shared between new/edit.
    Explicit url:, not model: [@event, registration_form] — this app's routes give every Admin::
    path its "admin_" prefix via `scope path: "admin", as: "admin"` (config/routes.rb), not a real
    `namespace :admin do`, which is the only shape polymorphic_url's array form actually detects;
    every other form in this app (e.g. admin/participants/_form.html.erb) already follows this
    same explicit-url convention for the same reason. %>
<%= form_with model: registration_form,
      url: registration_form.persisted? ? admin_event_registration_form_path(@event, registration_form) : admin_event_registration_forms_path(@event),
      local: true do |f| %>
  <% if registration_form.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% registration_form.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :name, class: "form-label" %>
    <%= f.text_field :name, class: field_error_class(registration_form, :name), placeholder: "e.g. VIP Registration" %>
    <%= field_error_feedback(registration_form, :name) %>
  </div>

  <h6 class="text-muted text-uppercase font-size-12">Fields</h6>
  <%# requirement.md v12 revisit: "position each and every field — order of the field should be
      configurable." Listed here in the catalog's own fixed order regardless of configured
      position (a plain "Pos." number column to edit, not live drag-reordering) — RegistrationForm
      #ordered_catalog_fields/TicketCategory#ordered_catalog_fields (read by the actual
      manual-entry form, admin/participants/_form.html.erb) are what apply it for real. %>
  <div class="mb-3">
    <% Event::PARTICIPANT_FIELD_CATALOG.each do |field| %>
      <%# first_name can't actually be turned off — TicketCategory#effective_catalog_fields
          force-merges it to true regardless, backed by Participant's own unconditional
          `validates :first_name, presence: true` — rendered checked-and-disabled with a hidden
          field resubmitting the value, same "make the UI honest about what it can't turn off"
          treatment badge-mandated fields used before forms became shareable across categories
          (this one's mandatoriness doesn't vary per category, so it doesn't have that problem). %>
      <% locked = field == "first_name" %>
      <div class="d-flex align-items-center justify-content-between border rounded px-3 py-2 mb-2">
        <%# form-switch, not a plain checkbox — same toggle styling as every other on/off field in
            this app (e.g. the Basic Info step's "Paid Event"/"Send a confirmation email"), just a
            checkbox underneath either way, so the assignment section's own :has()-driven CSS below
            still works unchanged against :checked. %>
        <div class="form-check form-switch mb-0">
          <%= check_box_tag "registration_form[catalog_fields][]", field, locked || registration_form.catalog_fields[field],
                id: "catalog_field_#{field}", class: "form-check-input", disabled: locked %>
          <%= hidden_field_tag "registration_form[catalog_fields][]", field if locked %>
          <%= label_tag "catalog_field_#{field}", field.humanize, class: "form-check-label" %>
          <% if locked %><small class="text-muted d-block">Always required</small><% end %>
        </div>
        <div class="d-flex align-items-center gap-2">
          <%= label_tag "catalog_field_position_#{field}", "Position", class: "form-label mb-0 text-muted font-size-12" %>
          <%= number_field_tag "registration_form[catalog_field_positions][#{field}]", registration_form.catalog_field_positions[field],
                id: "catalog_field_position_#{field}", class: "form-control form-control-sm", style: "width: 5rem;", min: 0 %>
        </div>
      </div>
    <% end %>
  </div>
  <hr />
  <%# requirement.md revisit: "we should have privilege to set the uniqueness for participant
      data. sometimes it will be unique by email, unique by contact num or both ... At least one
      uniqueness parameter should be set and same parameter should be used while importing the
      data." Participant.duplicate_match (read via TicketCategory#effective_uniqueness_fields) is
      the single place both the manual-entry form and ParticipantImportJob check against, so
      whatever's picked here applies identically to both. %>
  <h6 class="text-muted text-uppercase font-size-12">Duplicate Detection</h6>
  <div class="mb-3">
    <p class="text-muted mb-2">
      A new participant matching an existing one on any checked field (for this form's assigned
      categories) is treated as a duplicate — on manual entry and on bulk import alike. Choose at
      least one.
    </p>
    <% { "email" => "Email", "contact_num" => "Contact Number" }.each do |field, label| %>
      <div class="form-check form-switch mb-2">
        <%= check_box_tag "registration_form[uniqueness_fields][]", field, registration_form.uniqueness_fields.include?(field),
              id: "uniqueness_field_#{field}", class: "form-check-input" %>
        <%= label_tag "uniqueness_field_#{field}", label, class: "form-check-label" %>
      </div>
    <% end %>
    <%= field_error_feedback(registration_form, :uniqueness_fields) %>
  </div>
  <hr />
  <h6 class="text-muted text-uppercase font-size-12">Custom fields</h6>
  <div data-controller="nested-fields">
    <div data-nested-fields-target="container">
      <%= f.fields_for :custom_fields do |cf| %>
        <%= render "custom_field_fields", f: cf %>
      <% end %>
    </div>

    <template data-nested-fields-target="template">
      <%= f.fields_for :custom_fields, CustomField.new, child_index: "NEW_RECORD" do |cf| %>
        <%= render "custom_field_fields", f: cf %>
      <% end %>
    </template>

    <button type="button" class="btn btn-sm btn-outline-primary mb-0" data-action="nested-fields#add">
      <i class="bx bx-plus"></i> Add another field
    </button>
  </div>

  <hr>

  <%# Assignment — a separate concern from the field design above: which of the event's ticket
      categories should actually use this form. "Apply to ALL" is a one-time bulk assignment
      (Admin::RegistrationFormsController#assign_categories!), not a persisted flag — a category
      added to the event later doesn't retroactively inherit it. %>
  <h6 class="text-muted text-uppercase font-size-12">Assign to Ticket Categories</h6>
  <% assigned_ids = registration_form.persisted? ? registration_form.ticket_categories.ids : [] %>
  <% all_assigned = ticket_categories.any? && (ticket_categories.map(&:id) - assigned_ids).empty? %>
  <div class="registration-form-categories">
    <div class="form-check form-switch mb-2">
      <%= check_box_tag "registration_form[apply_to_all]", "1", all_assigned, id: "apply_to_all", class: "form-check-input" %>
      <%= label_tag "apply_to_all", "Apply to ALL ticket categories", class: "form-check-label fw-semibold" %>
    </div>

    <% if ticket_categories.none? %>
      <p class="text-muted">No ticket categories yet — add some from the event's Tickets step first.</p>
    <% else %>
      <%# CSS-driven, same :has()-off-live-DOM-state technique the Basic Info step's seat-limit
          fields and the old per-category custom-form panels both already use — the individual
          list only matters once "Apply to ALL" is unchecked (application.css). %>
      <div class="ticket-category-checkboxes row g-2">
        <% ticket_categories.each do |category| %>
          <div class="col-md-4 form-check form-switch">
            <%= check_box_tag "registration_form[ticket_category_ids][]", category.id, assigned_ids.include?(category.id),
                  id: "ticket_category_#{category.id}", class: "form-check-input" %>
            <%= label_tag "ticket_category_#{category.id}", category.name, class: "form-check-label" %>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>

  <div class="d-flex align-items-start gap-3 mt-4">
    <%= f.submit registration_form.persisted? ? "Save" : "Create Form", class: "btn btn-sm btn-primary" %>
    <%= link_to "Cancel", admin_event_registration_forms_path(@event), class: "btn btn-sm btn-outline-secondary" %>
  </div>
<% end %>
