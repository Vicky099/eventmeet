<%# Locals: f (a fields_for builder for one CustomField, real or unsaved).
    Ported from the Basic Info step's own _custom_field_fields.html.erb (Phase 7 — retired
    together with Event#custom_fields when this moved to RegistrationForm, Phase 7.5); same row
    markup, shared between the live list and the <template> the nested-fields Stimulus controller
    clones for "Add another field" (see _tickets_step.html.erb's identical pattern for
    TicketCategory). %>
<div class="row g-2 align-items-end mb-2" data-nested-fields-target="row">
  <div class="col-md-3">
    <%= f.label :label, class: "form-label" %>
    <%= f.text_field :label, class: field_error_class(f.object, :label), placeholder: "e.g. Dietary Requirements" %>
    <%= field_error_feedback(f.object, :label) %>
  </div>
  <div class="col-md-2">
    <%= f.label :field_type, "Type", class: "form-label" %>
    <%= f.select :field_type, CustomField.field_types.keys.map { |t| [ t.humanize, t ] }, {}, class: "form-select" %>
  </div>
  <div class="col-md-3">
    <%= f.label :options, "Choices (one per line, for Select)", class: "form-label" %>
    <%= f.text_area :options, class: field_error_class(f.object, :options), rows: 1 %>
    <%= field_error_feedback(f.object, :options) %>
  </div>
  <%# requirement.md v12 revisit: "position each and every field." Already a real column
      (RegistrationForm#custom_fields is already `-> { order(:position) }`) — this is just the
      first UI that ever exposed it; every existing custom field defaults to the schema's own `0`
      until an organizer sets one. %>
  <div class="col-md-1">
    <%= f.label :position, "Pos.", class: "form-label" %>
    <%= f.number_field :position, class: "form-control", min: 0 %>
  </div>
  <div class="col-md-2 form-check form-switch mb-1">
    <%= f.check_box :required, class: "form-check-input" %>
    <%= f.label :required, class: "form-check-label" %>
  </div>
  <div class="col-auto">
    <%= f.hidden_field :_destroy %>
    <button type="button" class="btn btn-sm btn-outline-danger" data-action="nested-fields#remove">Remove</button>
  </div>
</div>
