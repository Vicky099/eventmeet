<% content_for :page_title, @event.name %>

<%= render "shared/page_header",
  icon: "bx-calendar-event",
  crumbs: [ { label: "Events", path: admin_events_path }, { label: @event.name } ] %>

<div class="mb-3 d-flex gap-2">
  <span class="badge bg-info-subtle text-info"><%= @event.status.humanize %></span>
  <span class="badge <%= approval_status_badge_class(@event.approval_status) %>"><%= @event.approval_status.humanize %></span>
  <% if @event.published? %>
    <span class="badge bg-success-subtle text-success"><i class="bx bx-check-circle"></i> Published</span>
  <% end %>
</div>

<%# Sequential stepper wizard (requirement.md §5.2 revisited from Phase 4's freely-navigable
    autosaving tabs): each step's Next button does a real save before advancing, and Review ends
    in a Publish button instead of autosave-everywhere. Step icons stay clickable, same as the
    tabs they replace — nothing here is hard-gated except Publish itself
    (Event#basic_info_complete?). %>
<% steps = [
  { key: "basic_info", label: "Basic Info", icon: "bx-info-circle" },
  { key: "agenda", label: "Agenda", icon: "bx-list-ul" },
  { key: "tickets", label: "Ticket Categories", icon: "bx-purchase-tag-alt" },
  { key: "badge", label: "Badge", icon: "bx-id-card" },
  { key: "review", label: "Review", icon: "bx-check-double" },
] %>

<div class="card">
  <div class="card-body">
    <ul class="wizard-nav mb-4">
      <% steps.each do |step| %>
        <li class="wizard-list-item">
          <%= link_to edit_admin_event_path(@event, step: step[:key]),
                class: "list-item text-decoration-none #{'active' if @step == step[:key]}" do %>
            <div class="step-icon" data-bs-toggle="tooltip" data-bs-placement="top" title="<%= step[:label] %>">
              <i class="bx <%= step[:icon] %>"></i>
            </div>
            <div class="step-title text-muted"><%= step[:label] %></div>
          <% end %>
        </li>
      <% end %>
    </ul>

    <% case @step
       when "basic_info" %>
      <div class="text-center mb-4">
        <h5>Basic Info</h5>
        <% if @event.basic_info_complete? %>
          <p class="text-success mb-0"><i class="bx bx-check-circle"></i> Complete</p>
        <% else %>
          <p class="text-warning mb-0"><i class="bx bx-error-circle"></i> Incomplete</p>
        <% end %>
      </div>
      <%= render "basic_info_step", event: @event %>
    <% when "agenda" %>
      <div class="text-center mb-4"><h5>Agenda</h5></div>
      <%= render "shared/empty_state", icon: "bx-list-ul",
            message: "Multi-day, multi-track agenda planning lands in Phase 11." %>
      <div class="d-flex align-items-start gap-3 mt-4">
        <%= link_to "Previous", edit_admin_event_path(@event, step: "basic_info"), class: "btn btn-outline-secondary" %>
        <%= link_to "Next", edit_admin_event_path(@event, step: "tickets"), class: "btn btn-primary ms-auto" %>
      </div>
    <% when "tickets" %>
      <div class="text-center mb-4"><h5>Ticket Categories</h5></div>
      <%= render "shared/empty_state", icon: "bx-purchase-tag-alt",
            message: "Capacity-based ticket categories land in Phase 6." %>
      <div class="d-flex align-items-start gap-3 mt-4">
        <%= link_to "Previous", edit_admin_event_path(@event, step: "agenda"), class: "btn btn-outline-secondary" %>
        <%= link_to "Next", edit_admin_event_path(@event, step: "badge"), class: "btn btn-primary ms-auto" %>
      </div>
    <% when "badge" %>
      <div class="text-center mb-4"><h5>Badge</h5></div>
      <%= render "shared/empty_state", icon: "bx-id-card",
            message: "The visual badge designer lands in Phase 8." %>
      <div class="d-flex align-items-start gap-3 mt-4">
        <%= link_to "Previous", edit_admin_event_path(@event, step: "tickets"), class: "btn btn-outline-secondary" %>
        <%= link_to "Next", edit_admin_event_path(@event, step: "review"), class: "btn btn-primary ms-auto" %>
      </div>
    <% when "review" %>
      <div class="text-center mb-4"><h5>Review</h5></div>
      <%= render "review_step", event: @event %>
    <% end %>
  </div>
</div>
