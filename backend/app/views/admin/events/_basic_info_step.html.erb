<%# Locals: event.
    Step 1 of the wizard (requirement.md §5.2 revisited) — Next is a real PATCH
    (Admin::EventsController#update) that saves this step and advances, not autosave. %>
<%= form_with model: event, url: admin_event_path(event), method: :patch, data: { controller: "event-mode" } do |f| %>
  <%= hidden_field_tag :step, "basic_info" %>
  <% if event.errors.any? %>
    <div class="alert alert-danger">
      <ul class="mb-0">
        <% event.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="row g-3">
    <div class="col-md-8">
      <%= f.label :name, class: "form-label" %>
      <%= f.text_field :name, class: "form-control" %>
    </div>
    <div class="col-md-4">
      <%= f.label :mode, class: "form-label" %>
      <%= f.select :mode, Event.modes.keys.map { |m| [ m.humanize, m ] }, {},
            class: "form-select", data: { event_mode_target: "mode", action: "change->event-mode#toggle" } %>
    </div>

    <div class="col-md-6">
      <%= f.label :starts_at, "Starts", class: "form-label" %>
      <%= f.datetime_field :starts_at, class: "form-control" %>
    </div>
    <div class="col-md-6">
      <%= f.label :ends_at, "Ends", class: "form-label" %>
      <%= f.datetime_field :ends_at, class: "form-control" %>
    </div>

    <div class="col-md-6" data-event-mode-target="onSiteField">
      <%= f.label :address, class: "form-label" %>
      <%= f.text_area :address, class: "form-control", rows: 2 %>
      <small class="text-muted">Required for on-site/hybrid events.</small>
    </div>
    <div class="col-md-6" data-event-mode-target="onSiteField">
      <%= f.label :map_url, "Google Maps link", class: "form-label" %>
      <%= f.text_field :map_url, class: "form-control", placeholder: "https://maps.google.com/?q=..." %>
      <small class="text-muted">Paste a Google Maps location URL — used to render the map on the public event page.</small>
    </div>
    <div class="col-md-6" data-event-mode-target="virtualField">
      <%= f.label :meeting_link, class: "form-label" %>
      <%= f.text_field :meeting_link, class: "form-control" %>
      <small class="text-muted">Required for virtual/hybrid events.</small>
    </div>

    <div class="col-md-4">
      <%= f.label :banner_orientation, class: "form-label" %>
      <%= f.select :banner_orientation, Event.banner_orientations.keys.map { |o| [ o.humanize, o ] }, {}, class: "form-select" %>
    </div>
  </div>

  <hr>

  <h6 class="text-muted text-uppercase font-size-12">Required participant fields</h6>
  <div class="d-flex flex-wrap gap-3 mb-3">
    <% Event::PARTICIPANT_FIELD_CATALOG.each do |field| %>
      <div class="form-check">
        <%= check_box_tag "event[participant_fields][#{field}]", "true", event.participant_fields[field],
              id: "participant_field_#{field}", class: "form-check-input" %>
        <%= label_tag "participant_field_#{field}", field.humanize, class: "form-check-label" %>
      </div>
    <% end %>
  </div>

  <div class="d-flex align-items-start gap-3 mt-4">
    <%= f.submit "Next", class: "btn btn-primary ms-auto" %>
  </div>
<% end %>
