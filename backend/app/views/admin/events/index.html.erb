<% content_for :page_title, "Events" %>

<%# Fixed-hierarchy pivot (requirement.md revisit): every tenant's Account belongs to an Agency now
    — no more quotation-picker modal, no per-event Super Admin approval round trip. "New Event"
    links straight to #new, gated only on the agency's own contract actually being active
    (Event#agency_contract_must_be_active is the real, model-level gate; this is just keeping the
    button from inviting a doomed submit). %>
<%= render layout: "shared/page_header", locals: { icon: "bx-calendar-event", crumbs: [ { label: "Events" } ] } do %>
  <% if @agency&.contract_active? %>
    <%= link_to new_admin_event_path, class: "btn btn-m btn-primary" do %>
      <i class="bx bx-plus"></i> New Event
    <% end %>
  <% else %>
    <button type="button" class="btn btn-m btn-primary" disabled title="<%= @agency.nil? ? "This tenant has no agency" : (@agency.annual? ? "Your agency's annual contract hasn't been paid yet" : "No event slots remaining — ask the Super Admin to grant more") %>">
      <i class="bx bx-plus"></i> New Event
    </button>
  <% end %>
<% end %>

<% if @agency&.per_event? %>
  <p class="text-muted mb-3"><%= @agency.name %>'s event pool: <%= @agency.events_used %> used / <%= @agency.events_granted %> granted (<%= @agency.events_remaining %> remaining).</p>
<% elsif @agency&.annual? %>
  <p class="text-muted mb-3"><%= @agency.name %>'s annual contract — unlimited events.</p>
<% end %>

<div class="mb-3">
  <%= form_with url: admin_events_path, method: :get, local: true, class: "d-flex gap-2" do %>
    <%# id: "event_status_filter", not the Rails-default id="status" — the vendored admin
        template's own CSS has a bare #status selector rule that collides with it otherwise. %>
    <%= select_tag :status,
          options_for_select([ [ "All statuses", "" ] ] + Event.statuses.keys.map { |s| [ s.humanize, s ] }, @status_filter),
          id: "event_status_filter", class: "form-select", onchange: "this.form.requestSubmit()" %>
  <% end %>
</div>

<div class="card">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th>Name</th>
            <th>Mode</th>
            <th>Starts</th>
            <th>Status</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @events.each do |event| %>
            <tr>
              <td><%= link_to event.name, admin_event_path(event) %></td>
              <td><%= event.mode.humanize %></td>
              <td><%= event.starts_at.to_fs(:short) %></td>
              <td><span class="badge bg-info-subtle text-info"><%= event.status.humanize %></span></td>
              <td class="text-end">
                <div class="d-flex justify-content-end gap-2">
                  <%# requirement.md revisit: "once event complete the tenant can not able to edit
                      the event" — EventPolicy#update? is the real, server-side gate (also covers
                      every wizard step and Sessions/Speaker/Schedule/Badge sub-resource, all of
                      which authorize through this same Event); this just keeps a completed row
                      from showing a link that would only ever redirect back with "not authorized." %>
                  <% if policy(event).update? %>
                    <%= link_to edit_admin_event_path(event), class: "btn btn-m btn-outline-primary", title: "Edit" do %>
                      <i class="bx bx-edit"></i>
                    <% end %>
                  <% else %>
                    <button type="button" class="btn btn-m btn-outline-primary" disabled title="Completed events can no longer be edited">
                      <i class="bx bx-edit"></i>
                    </button>
                  <% end %>
                  <%# Event duplication/template action (requirement.md Phase 4) — full clone logic
                      lives in Admin::EventsController#duplicate; consumes another slot from the
                      account's own Agency, same gate as "New Event" above. %>
                  <%= button_to duplicate_admin_event_path(event), method: :post,
                        class: "btn btn-m btn-outline-secondary", title: "Duplicate",
                        disabled: !@agency&.contract_active? do %>
                    <i class="bx bx-copy"></i>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
          <% if @events.none? %>
            <tr><td colspan="5" class="text-center text-muted py-4">No events yet.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
