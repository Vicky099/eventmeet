<%# Locals: event.
    Final step — read-only summary, then Publish. Fixed-hierarchy pivot (requirement.md revisit):
    no more Super Admin approval gate — Publish only ever needed basic_info_complete? now
    (Admin::EventsController#publish). Editing any earlier step's content after publishing reverts
    the event to draft again (Event#revert_to_draft_if_published_content_changed), so the Publish
    button reappears then.

    Every section below is its own card (user feedback — was one long card-body with <hr>
    separators between blocks) — Event Details/Ticket Categories/Badges/Speakers+Agenda (a row of
    two side by side)/Publish, each read-only; editing happens back on the step/page that owns
    that data, consistent with the rest of this page (there's no "edit Basic Info from Review"
    either). %>
<div class="card mb-3">
  <div class="card-header"><span class="fw-semibold">Event Details</span></div>
  <div class="card-body">
    <dl class="row mb-0">
      <dt class="col-sm-3">Name</dt>
      <dd class="col-sm-9"><%= event.name %></dd>

      <dt class="col-sm-3">Mode</dt>
      <dd class="col-sm-9"><%= event.mode.humanize %></dd>

      <dt class="col-sm-3">Schedule</dt>
      <dd class="col-sm-9">
        <% if event.starts_at && event.ends_at %>
          <%= event.starts_at.to_fs(:long) %> &rarr; <%= event.ends_at.to_fs(:long) %>
        <% else %>
          <span class="text-muted">Not set</span>
        <% end %>
      </dd>

      <dt class="col-sm-3">Location</dt>
      <dd class="col-sm-9">
        <% if event.address.present? %><div><%= event.address %></div><% end %>
        <% if event.map_url.present? %><div><%= external_link_to "Map link", event.map_url %></div><% end %>
        <% if event.meeting_link.present? %><div><%= external_link_to event.meeting_link, event.meeting_link %></div><% end %>
        <% if event.address.blank? && event.meeting_link.blank? %><span class="text-muted">Not set</span><% end %>
      </dd>

      <dt class="col-sm-3">Status</dt>
      <dd class="col-sm-9 mb-0"><span class="badge bg-info-subtle text-info"><%= event.status.humanize %></span></dd>
    </dl>
  </div>
</div>

<div class="card mb-3">
  <div class="card-header"><span class="fw-semibold">Ticket Categories</span></div>
  <div class="card-body">
    <% if event.ticket_categories.none? %>
      <p class="text-muted mb-0">None added yet.</p>
    <% else %>
      <div class="table-responsive">
        <table class="table table-sm align-middle mb-0">
          <thead>
            <tr>
              <th>Name</th>
              <th>Total seats</th>
              <th>Sold</th>
              <th>Remaining</th>
              <th>Document required</th>
            </tr>
          </thead>
          <tbody>
            <% event.ticket_categories.each do |category| %>
              <tr>
                <td><%= category.name %></td>
                <td><%= category.total_count || "Unlimited" %></td>
                <td><%= category.sold_count %></td>
                <td><%= category.remain_count || "—" %></td>
                <td><%= category.document_required? ? "Yes" : "No" %></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      </div>
    <% end %>
  </div>
</div>

<div class="card mb-3">
  <div class="card-header"><span class="fw-semibold">Badges</span></div>
  <div class="card-body">
    <%= render "admin/badges/badges_table", event: event,
          badges: event.badges.includes(:ticket_category).order(:ticket_category_id), actions: false %>
  </div>
</div>

<%# Phase 11 — the real roster/agenda detail, not just a count (a plain "3 sessions, 2 speakers,
    5 talks scheduled" line told the tenant *that* something existed but nothing about *what*) —
    read-only, same "editing happens back on the step/page that owns that data" split every other
    card on this page already follows. Two cards side by side (Speakers/Agenda), not one shared
    "Agenda & Speakers" card with two subsections — reads as two distinct pieces of content even
    though they're related, same shape the row-of-cards further down this page doesn't use, but
    the Basic Info step's own two-column field rows already establish as this app's pattern for
    "related, but visually separate" content. %>
<% speakers = event.speakers.order(:name)
   sessions = event.sessions.includes(schedules: :speaker).order(:starts_at)
   days = sessions.group_by { |session| session.starts_at.to_date }
   unscheduled_talks = event.schedules.where(session_id: nil).includes(:speaker).order(:starts_at) %>
<div class="row g-3 mb-3">
  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-header"><span class="fw-semibold">Speakers</span></div>
      <div class="card-body">
        <% if speakers.none? %>
          <p class="text-muted mb-0">No speakers added yet.</p>
        <% else %>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead>
                <tr>
                  <th></th>
                  <th>Name</th>
                  <th>Company</th>
                  <th>Contact</th>
                </tr>
              </thead>
              <tbody>
                <% speakers.each do |speaker| %>
                  <tr>
                    <td>
                      <% if speaker.photo.attached? %>
                        <%# Not image_tag(attachment) — 500s the moment it's exercised against a
                            real attached photo ("no implicit conversion of
                            ActiveStorage::Attached::One into String"), compounded by this app's
                            config/cloudinary.yml `enhance_image_tag: true` mangling any URL
                            string fed to image_tag instead (see checkin/_result.html.erb's own
                            comment, where this was first caught live). A bare <img> via
                            `tag.img` sidesteps image_tag entirely. %>
                        <%= tag.img src: speaker.photo.url, class: "rounded-circle", style: "width: 28px; height: 28px; object-fit: cover;" %>
                      <% else %>
                        <i class="bx bx-user-circle font-size-20 text-muted"></i>
                      <% end %>
                    </td>
                    <td><%= speaker.name %></td>
                    <td><%= speaker.company.presence || "—" %></td>
                    <td><%= [ speaker.email, speaker.contact_num ].compact_blank.join(" · ").presence || "—" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    </div>
  </div>

  <div class="col-md-6">
    <div class="card h-100">
      <div class="card-header"><span class="fw-semibold">Agenda</span></div>
      <div class="card-body">
        <% if days.empty? && unscheduled_talks.none? %>
          <p class="text-muted mb-0">No sessions or talks scheduled yet.</p>
        <% else %>
          <%# Each session (and each session-less talk) gets its own bordered box — same visual
              language _event_schedule_step.html.erb's own editing UI already uses for a session
              card, just without its Edit/Remove/Add actions (read-only, per this whole page's own
              rule). %>
          <% days.sort.each do |day, sessions_for_day| %>
            <h6 class="text-muted font-size-12 fw-normal mb-2"><%= day.strftime("%A, %B %-d") %></h6>
            <% sessions_for_day.sort_by(&:starts_at).each do |session| %>
              <div class="border rounded p-2 mb-2">
                <div class="fw-semibold font-size-13">
                  <%= session.name %>
                  <span class="text-muted font-size-12 fw-normal">
                    (<%= session.starts_at.strftime("%H:%M") %>&ndash;<%= session.ends_at.strftime("%H:%M") %><%
                      %><%= ", #{session.track}" if session.track.present? %><%= ", #{session.room}" if session.room.present? %>)
                  </span>
                </div>
                <% if session.schedules.any? %>
                  <ul class="list-unstyled mt-2 mb-0 font-size-13">
                    <% session.schedules.sort_by(&:starts_at).each do |schedule| %>
                      <li><%= schedule.title %> &mdash; <%= schedule.speaker.name %> (<%= schedule.starts_at.strftime("%H:%M") %>)</li>
                    <% end %>
                  </ul>
                <% end %>
              </div>
            <% end %>
          <% end %>

          <% if unscheduled_talks.any? %>
            <h6 class="text-muted font-size-12 fw-normal mt-3 mb-2">Other Talks (no session)</h6>
            <% unscheduled_talks.each do |schedule| %>
              <div class="border rounded p-2 mb-2 font-size-13">
                <%= schedule.title %> &mdash; <%= schedule.speaker.name %> (<%= schedule.starts_at.strftime("%b %-d, %H:%M") %>)
              </div>
            <% end %>
          <% end %>
        <% end %>
      </div>
    </div>
  </div>
</div>

<%# Deliberately no Participants card: this page is reviewing the *event's own setup*, and there's
    no participant workflow at event-creation time — nobody registers for an event that isn't
    published yet, so a "0 participants" line here was reviewing something that structurally can't
    exist at this point, not a genuinely missing piece of the event's own data. Once the event is
    live, participant counts belong on its own dashboard/Participants page, not this setup-review
    step. %>

<div class="card mb-3">
  <div class="card-header"><span class="fw-semibold">Publish</span></div>
  <div class="card-body">
    <% if event.published? %>
      <div class="alert alert-success mb-0">
        <i class="bx bx-check-circle me-1"></i> Published — current status: <%= event.status.humanize %>. Editing an earlier step will move it back to Draft.
      </div>
    <% elsif event.basic_info_complete? %>
      <p class="text-muted">Publishing hands this event to the schedule — it moves out of Draft into Upcoming/Live/Completed automatically from here.</p>
      <%= button_to "Publish", publish_admin_event_path(event), method: :post, class: "btn btn-m btn-success" %>
    <% else %>
      <div class="alert alert-warning mb-0">
        <i class="bx bx-error-circle me-1"></i> Finish the Basic Info step before this event can be published.
      </div>
    <% end %>

    <p class="text-muted font-size-13 mt-3 mb-0">
      <i class="bx bx-info-circle me-1"></i> The event isn't visible on the public site until it's published.
    </p>
  </div>
</div>

<div class="d-flex align-items-start gap-3 mt-4">
  <%= link_to "Previous", edit_admin_event_path(event, step: "badge"), class: "btn btn-m btn-outline-secondary" %>
</div>
