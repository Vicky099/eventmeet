<%# Locals: event.
    Final step — read-only summary plus the Publish button (Event#publish!, requirement.md §5.2
    revisited). Editing any earlier step's content after publishing reverts the event to draft
    again (Event#revert_to_draft_if_published_content_changed), so this button reappears then. %>
<dl class="row mb-0">
  <dt class="col-sm-3">Name</dt>
  <dd class="col-sm-9"><%= event.name %></dd>

  <dt class="col-sm-3">Mode</dt>
  <dd class="col-sm-9"><%= event.mode.humanize %></dd>

  <dt class="col-sm-3">Schedule</dt>
  <dd class="col-sm-9">
    <% if event.starts_at && event.ends_at %>
      <%= event.starts_at.to_fs(:long) %> &rarr; <%= event.ends_at.to_fs(:long) %>
    <% else %>
      <span class="text-muted">Not set</span>
    <% end %>
  </dd>

  <dt class="col-sm-3">Location</dt>
  <dd class="col-sm-9">
    <% if event.address.present? %><div><%= event.address %></div><% end %>
    <% if event.map_url.present? %><div><%= external_link_to "Map link", event.map_url %></div><% end %>
    <% if event.meeting_link.present? %><div><%= external_link_to event.meeting_link, event.meeting_link %></div><% end %>
    <% if event.address.blank? && event.meeting_link.blank? %><span class="text-muted">Not set</span><% end %>
  </dd>

  <dt class="col-sm-3">Required fields</dt>
  <dd class="col-sm-9">
    <% required = event.participant_fields.select { |_, v| v }.keys %>
    <% if required.any? %>
      <%= required.map(&:humanize).join(", ") %>
    <% else %>
      <span class="text-muted">None</span>
    <% end %>
  </dd>

  <dt class="col-sm-3">Status</dt>
  <dd class="col-sm-9"><span class="badge bg-info-subtle text-info"><%= event.status.humanize %></span></dd>

  <dt class="col-sm-3">Approval</dt>
  <dd class="col-sm-9">
    <span class="badge <%= approval_status_badge_class(event.approval_status) %>"><%= event.approval_status.humanize %></span>
  </dd>
</dl>

<hr>

<% if event.published? %>
  <div class="alert alert-success mb-0">
    <i class="bx bx-check-circle me-1"></i> Published — current status: <%= event.status.humanize %>. Editing an earlier step will move it back to Draft.
  </div>
<% elsif event.basic_info_complete? %>
  <p class="text-muted">Publishing hands this event to the schedule — it moves out of Draft into Upcoming/Live/Completed automatically from here.</p>
  <%= button_to "Publish", publish_admin_event_path(event), method: :post, class: "btn btn-success" %>
<% else %>
  <div class="alert alert-warning mb-0">
    <i class="bx bx-error-circle me-1"></i> Finish the Basic Info step before this event can be published.
  </div>
<% end %>

<hr>

<%# Phase 5 — Event Approval Workflow (requirement.md §4.7 item 2, §5.2): independent of Publish
    above — a Super Admin decides public visibility here, regardless of the event's own
    draft/scheduled-live status. An event only ever enters the Super Admin's review queue once
    explicitly submitted (unsubmitted -> pending via Event#submit_for_review!) — it isn't there
    from the moment it's created. Re-approval-on-edit (§5.2 v8): once approved, further edits do
    NOT revert this, unlike Publish's status/draft cycle — no button to resubmit an approved
    event, because there's nothing to resubmit. %>
<% case event.approval_status %>
<% when "unsubmitted" %>
  <p class="text-muted">Not yet submitted — a Super Admin only sees this event once you submit it for review.</p>
  <%= button_to "Submit for review", submit_for_review_admin_event_path(event), method: :post, class: "btn btn-outline-primary" %>
<% when "pending" %>
  <p class="text-muted mb-0">
    <i class="bx bx-time-five me-1"></i> Awaiting Super Admin review<% if event.submitted_at %> — submitted <%= time_ago_in_words(event.submitted_at) %> ago<% end %>. Typically reviewed within 24 hours.
  </p>
<% when "approved" %>
  <div class="alert alert-success mb-0">
    <i class="bx bx-check-circle me-1"></i> Approved<% if event.approved_at %> <%= time_ago_in_words(event.approved_at) %> ago<% end %> — visible on the public site once published.
  </div>
<% when "rejected" %>
  <div class="alert alert-danger">
    <i class="bx bx-error-circle me-1"></i> Rejected: <%= event.rejection_reason %>
  </div>
  <%= button_to "Resubmit for review", submit_for_review_admin_event_path(event), method: :post, class: "btn btn-outline-primary" %>
<% end %>

<p class="text-muted font-size-13 mt-3 mb-0">
  <i class="bx bx-info-circle me-1"></i> Publishing and Super Admin approval are independent — the event isn't visible on the public site until it's both published <em>and</em> approved.
</p>

<div class="d-flex align-items-start gap-3 mt-4">
  <%= link_to "Previous", edit_admin_event_path(event, step: "badge"), class: "btn btn-outline-secondary" %>
</div>
