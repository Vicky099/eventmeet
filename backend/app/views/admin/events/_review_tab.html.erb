<%# Locals: event.
    Read-only summary — no submit-for-review action yet (Event#submit_for_review!, the
    SuperAdmin review queue, and this tab's actual "Submit" button are all Phase 5). %>
<dl class="row mb-0">
  <dt class="col-sm-3">Name</dt>
  <dd class="col-sm-9"><%= event.name %></dd>

  <dt class="col-sm-3">Mode</dt>
  <dd class="col-sm-9"><%= event.mode.humanize %></dd>

  <dt class="col-sm-3">Schedule</dt>
  <dd class="col-sm-9">
    <% if event.starts_at && event.ends_at %>
      <%= event.starts_at.to_fs(:long) %> &rarr; <%= event.ends_at.to_fs(:long) %>
    <% else %>
      <span class="text-muted">Not set</span>
    <% end %>
  </dd>

  <dt class="col-sm-3">Location</dt>
  <dd class="col-sm-9">
    <% if event.address.present? %><div><%= event.address %></div><% end %>
    <% if event.map_url.present? %><div><%= link_to "Map link", event.map_url %></div><% end %>
    <% if event.meeting_link.present? %><div><%= link_to event.meeting_link, event.meeting_link %></div><% end %>
    <% if event.address.blank? && event.meeting_link.blank? %><span class="text-muted">Not set</span><% end %>
  </dd>

  <dt class="col-sm-3">Required fields</dt>
  <dd class="col-sm-9">
    <% required = event.participant_fields.select { |_, v| v }.keys %>
    <% if required.any? %>
      <%= required.map(&:humanize).join(", ") %>
    <% else %>
      <span class="text-muted">None</span>
    <% end %>
  </dd>

  <dt class="col-sm-3">Status</dt>
  <dd class="col-sm-9"><span class="badge bg-info-subtle text-info"><%= event.status.humanize %></span></dd>

  <dt class="col-sm-3">Approval</dt>
  <dd class="col-sm-9"><span class="badge bg-warning-subtle text-warning"><%= event.approval_status.humanize %></span></dd>
</dl>

<hr>

<% if event.basic_info_complete? %>
  <div class="alert alert-info mb-0">
    <i class="bx bx-info-circle me-1"></i> Submitting this event for Super Admin review lands in Phase 5 — once built, this is where you'll publish it.
  </div>
<% else %>
  <div class="alert alert-warning mb-0">
    <i class="bx bx-error-circle me-1"></i> Finish the Basic Info tab before this event is ready to submit.
  </div>
<% end %>
