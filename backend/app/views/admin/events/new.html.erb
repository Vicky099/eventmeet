<% content_for :page_title, "New Event" %>

<%= render "shared/page_header",
  icon: "bx-calendar-event",
  crumbs: [ { label: "Events", path: admin_events_path }, { label: "New Event" } ] %>

<div class="row">
  <div class="col-xl-7 col-lg-9">
    <div class="card">
      <div class="card-body">
        <%# A minimal creation form, not the full wizard — just enough to get a persisted record
            to hand off to. Once created, every one of these same fields becomes re-editable from
            the wizard's Basic Info step (edit.html.erb + _basic_info_step.html.erb). %>
        <%# No top-of-form error summary — every field shows its own error inline, directly below
            itself (field_error_class/field_error_feedback, app/helpers/application_helper.rb),
            same treatment the wizard's own Basic Info step uses. %>
        <%= form_with model: @event, url: admin_events_path, local: true, data: { controller: "event-mode" } do |f| %>
          <%# Phase 15, revisited (requirement.md §4.6, confirmed with the user): the quotation is
              picked before this form is ever reached (Admin::Events index's own picker modal) —
              shown here locked, not re-editable, plus a hidden field so #create can re-verify it.
              One quotation -> one event, so this is a one-shot association, not a form field.
              @event.quotation may be nil/invalid on a re-render after a failed #create (a stray
              or already-consumed quotation_id) — field_error_feedback below is what explains it. %>
          <div class="mb-3">
            <label class="form-label">Quotation</label>
            <% if @event.quotation %>
              <div class="form-control-plaintext bg-light rounded px-3 py-2">
                <strong><%= @event.quotation.event_name %></strong> — <%= money(@event.quotation.current_amount, @event.quotation.currency) %>
              </div>
            <% else %>
              <div class="alert alert-warning mb-0">
                <%= link_to "Select an approved quotation", admin_events_path, class: "alert-link" %> to continue.
              </div>
            <% end %>
            <%= f.hidden_field :quotation_id, value: @event.quotation&.id %>
            <%= field_error_feedback(@event, :quotation_id) %>
            <%= field_error_feedback(@event, :quotation) %>
          </div>

          <div class="mb-3">
            <%= f.label :name, class: "form-label" %>
            <%= f.text_field :name, class: field_error_class(@event, :name), autofocus: true %>
            <%= field_error_feedback(@event, :name) %>
          </div>

          <div class="mb-3">
            <%= f.label :mode, class: "form-label" %>
            <%= f.select :mode, Event.modes.keys.map { |m| [ m.humanize, m ] }, {},
                  class: "form-select", data: { event_mode_target: "mode", action: "change->event-mode#toggle" } %>
          </div>

          <div class="row g-3 mb-3">
            <div class="col-md-6">
              <%= f.label :starts_at, "Starts", class: "form-label" %>
              <%= f.datetime_field :starts_at, class: field_error_class(@event, :starts_at) %>
              <%= field_error_feedback(@event, :starts_at) %>
            </div>
            <div class="col-md-6">
              <%= f.label :ends_at, "Ends", class: "form-label" %>
              <%= f.datetime_field :ends_at, class: field_error_class(@event, :ends_at) %>
              <%= field_error_feedback(@event, :ends_at) %>
            </div>
          </div>

          <div class="mb-3" data-event-mode-target="onSiteField">
            <%= f.label :address, class: "form-label" %>
            <%= f.text_area :address, class: field_error_class(@event, :address), rows: 2 %>
            <%= field_error_feedback(@event, :address) %>
            <small class="text-muted">Required for on-site/hybrid events.</small>
          </div>

          <div class="mb-3" data-event-mode-target="onSiteField">
            <%= f.label :map_url, "Google Maps link", class: "form-label" %>
            <%= f.text_field :map_url, class: field_error_class(@event, :map_url), placeholder: "https://maps.google.com/?q=..." %>
            <%= field_error_feedback(@event, :map_url) %>
            <small class="text-muted">Required for on-site/hybrid events. Paste a Google Maps location URL — used to render the map on the public event page.</small>
          </div>

          <div class="mb-3" data-event-mode-target="virtualField">
            <%= f.label :meeting_link, class: "form-label" %>
            <%= f.text_field :meeting_link, class: field_error_class(@event, :meeting_link) %>
            <%= field_error_feedback(@event, :meeting_link) %>
            <small class="text-muted">Required for virtual/hybrid events.</small>
          </div>

          <%= f.submit "Create Event", class: "btn btn-sm btn-primary" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
