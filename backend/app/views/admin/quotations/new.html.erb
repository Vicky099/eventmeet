<% content_for :page_title, "Request Quotation" %>

<%= render "shared/page_header",
  icon: "bx-receipt", crumbs: [ { label: "Quotations", path: admin_quotations_path }, { label: "Request" } ] %>

<div class="row">
  <div class="col-xl-7 col-lg-9">
    <div class="card">
      <div class="card-body">
        <p class="text-muted">
          Every event is priced individually. Tell us what the event is for and a Super Admin will
          send you a price — the event itself can only be created once you approve it.
        </p>
        <%= form_with model: @quotation, url: admin_quotations_path, local: true do |f| %>
          <div class="mb-3">
            <%= f.label :event_name, "What's this event for?", class: "form-label" %>
            <%= f.text_field :event_name, class: field_error_class(@quotation, :event_name), autofocus: true, placeholder: "e.g. Annual Leadership Summit 2026" %>
            <%= field_error_feedback(@quotation, :event_name) %>
          </div>

          <div class="mb-3">
            <%= f.label :expected_participant_count, "Expected number of participants", class: "form-label" %>
            <%= f.number_field :expected_participant_count, min: 1, step: 1, class: field_error_class(@quotation, :expected_participant_count) %>
            <%= field_error_feedback(@quotation, :expected_participant_count) %>
            <small class="text-muted">A Super Admin prices your event based on this — give your best estimate.</small>
          </div>

          <div class="mb-3">
            <label class="form-label d-block">Send invitations via</label>
            <div class="form-check form-check-inline">
              <%= f.check_box :invite_via_email, class: "form-check-input" %>
              <%= f.label :invite_via_email, "Email", class: "form-check-label" %>
            </div>
            <div class="form-check form-check-inline">
              <%= f.check_box :invite_via_whatsapp, class: "form-check-input" %>
              <%= f.label :invite_via_whatsapp, "WhatsApp", class: "form-check-label" %>
            </div>
          </div>

          <div class="mb-3">
            <div class="form-check">
              <%= f.check_box :support_requested, class: "form-check-input" %>
              <%= f.label :support_requested, "I'll need platform support during the event", class: "form-check-label" %>
            </div>
          </div>

          <div class="mb-3">
            <%= f.label :additional_notes, "Anything else the Super Admin should know?", class: "form-label" %>
            <%= f.text_area :additional_notes, rows: 3, class: "form-control", placeholder: "Optional — special requirements, dates, venue details, etc." %>
          </div>

          <%= f.submit "Request Quotation", class: "btn btn-sm btn-primary" %>
        <% end %>
      </div>
    </div>
  </div>
</div>
