<% content_for :page_title, "Quotations" %>

<%= render layout: "shared/page_header",
  locals: { icon: "bx-receipt", crumbs: [ { label: "Quotations" } ] } do %>
  <%= link_to "Request Quotation", new_admin_quotation_path, class: "btn btn-sm btn-primary" %>
<% end %>

<div class="card">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th>Event</th>
            <th>Amount</th>
            <th>Status</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @quotations.each do |quotation| %>
            <tr>
              <td><%= link_to quotation.event_name, admin_quotation_path(quotation) %></td>
              <td><%= quotation.current_amount ? money(quotation.current_amount, quotation.currency) : "Awaiting Super Admin" %></td>
              <td>
                <% case quotation.status
                   when "approved" %>
                  <span class="badge bg-success-subtle text-success">Approved</span>
                <% when "cancelled" %>
                  <span class="badge bg-secondary-subtle text-secondary">Cancelled</span>
                <% when "rejected" %>
                  <span class="badge bg-warning-subtle text-warning">Rejected — awaiting revision</span>
                <% else %>
                  <span class="badge bg-info-subtle text-info"><%= quotation.current_amount.present? ? "Awaiting your decision" : "Awaiting amount" %></span>
                <% end %>
              </td>
              <td class="text-end">
                <div class="d-flex justify-content-end gap-2">
                  <% if quotation.approved? && quotation.event.nil? %>
                    <%= link_to "Create Event", new_admin_event_path(quotation_id: quotation.id), class: "btn btn-sm btn-primary" %>
                  <% end %>
                  <%= link_to admin_quotation_path(quotation), class: "btn btn-sm btn-outline-primary", title: "View" do %>
                    <i class="bx bx-show"></i>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
          <% if @quotations.none? %>
            <tr><td colspan="4" class="text-center text-muted py-4">No event requests yet.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
