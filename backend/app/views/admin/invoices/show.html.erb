<% content_for :page_title, @invoice.event.name %>

<%= render "shared/page_header",
  icon: "bx-credit-card", crumbs: [ { label: "Invoices", path: admin_invoices_path }, { label: @invoice.event.name } ] %>

<div class="row">
  <div class="col-lg-7">
    <div class="card mb-3">
      <div class="card-header bg-white">
        <h5 class="card-title mb-0">Invoice</h5>
      </div>
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-4">Event</dt>
          <dd class="col-sm-8"><%= @invoice.event.name %></dd>

          <dt class="col-sm-4">Amount</dt>
          <dd class="col-sm-8"><strong><%= money(@invoice.amount, @invoice.currency) %></strong></dd>

          <dt class="col-sm-4">Status</dt>
          <dd class="col-sm-8 mb-0"><%= @invoice.status.humanize %></dd>
        </dl>
      </div>
    </div>

    <% if @invoice.utr_reference.present? %>
      <div class="card mb-3">
        <div class="card-header bg-white">
          <h5 class="card-title mb-0">Payment Submission</h5>
        </div>
        <div class="card-body">
          <dl class="row mb-0">
            <dt class="col-sm-4">UTR</dt>
            <dd class="col-sm-8"><%= @invoice.utr_reference %></dd>

            <dt class="col-sm-4">Submitted</dt>
            <dd class="col-sm-8"><%= @invoice.submitted_at&.to_fs(:short) %></dd>

            <% if @invoice.receipt.attached? %>
              <dt class="col-sm-4">Receipt</dt>
              <dd class="col-sm-8"><%= link_to "View receipt", rails_blob_path(@invoice.receipt) %></dd>
            <% end %>

            <% if @invoice.rejection_reason.present? %>
              <dt class="col-sm-4">Rejection reason</dt>
              <dd class="col-sm-8 text-danger"><%= @invoice.rejection_reason %></dd>
            <% end %>
          </dl>
        </div>
      </div>
    <% end %>
  </div>

  <div class="col-lg-5">
    <% if @invoice.awaiting_payment? %>
      <div class="card">
        <div class="card-header bg-white">
          <h5 class="card-title mb-0"><%= @invoice.rejection_reason.present? ? "Resubmit Payment" : "Submit Payment" %></h5>
        </div>
        <div class="card-body">
          <p class="text-muted font-size-13">
            Pay <strong><%= money(@invoice.amount, @invoice.currency) %></strong> via bank transfer (NEFT/IMPS), then submit the UTR and a receipt.
          </p>
          <button type="button" class="btn btn-sm btn-primary w-100" data-bs-toggle="modal" data-bs-target="#mark-as-paid-<%= @invoice.id %>">
            Mark as Paid
          </button>
        </div>
      </div>
    <% elsif @invoice.under_review? %>
      <div class="alert alert-info">Payment proof submitted — awaiting Super Admin review.</div>
    <% elsif @invoice.paid? %>
      <div class="alert alert-success">Paid — thank you.</div>
    <% else %>
      <div class="alert alert-secondary">This invoice is still in draft — not yet sent.</div>
    <% end %>
  </div>
</div>

<% if @invoice.awaiting_payment? %>
  <div class="modal fade" id="mark-as-paid-<%= @invoice.id %>" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content border-0 shadow">
        <%= form_with url: submit_payment_admin_invoice_path(@invoice), method: :post, local: true, multipart: true do %>
          <div class="modal-header border-0 pb-0">
            <h5 class="modal-title fw-semibold">Mark as Paid — <%= @invoice.event.name %></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <p class="fw-semibold mb-1">Amount due: <%= money(@invoice.amount, @invoice.currency) %></p>

            <div class="border rounded p-2 mb-3 bg-light">
              <p class="text-muted font-size-12 mb-1">Pay via NEFT/IMPS to:</p>
              <dl class="row mb-0 font-size-13">
                <dt class="col-5">Account name</dt><dd class="col-7"><%= PlatformBankDetails::ACCOUNT_NAME %></dd>
                <dt class="col-5">Account number</dt><dd class="col-7"><%= PlatformBankDetails::ACCOUNT_NUMBER %></dd>
                <dt class="col-5">IFSC code</dt><dd class="col-7"><%= PlatformBankDetails::IFSC_CODE %></dd>
                <dt class="col-5">Bank</dt><dd class="col-7"><%= PlatformBankDetails::BANK_NAME %>, <%= PlatformBankDetails::BRANCH %></dd>
              </dl>
            </div>

            <div class="mb-3">
              <%= label_tag :utr_reference, "UTR / reference number", class: "form-label" %>
              <%= text_field_tag :utr_reference, nil, class: "form-control", required: true %>
            </div>

            <div class="mb-3">
              <%= label_tag :receipt, "Transaction receipt (image or PDF)", class: "form-label" %>
              <%= file_field_tag :receipt, class: "form-control", accept: "image/*,application/pdf" %>
            </div>
          </div>
          <div class="modal-footer border-0 pt-3">
            <button type="button" class="btn btn-outline-secondary btn-sm" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary btn-sm">Mark as Paid</button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
