<% content_for :page_title, "Badges — #{@event.name}" %>

<%= render layout: "shared/page_header",
  locals: { icon: "bx-id-card", crumbs: [ { label: "Events", path: admin_events_path }, { label: @event.name, path: edit_admin_event_path(@event) }, { label: "Badges" } ] } do %>
  <%= link_to "New Badge", new_admin_event_badge_path(@event), class: "btn btn-m btn-primary" %>
<% end %>

<div class="card">
  <div class="card-header">
    <span class="fw-semibold">Badges</span>
  </div>
  <div class="card-body">
    <%= render "admin/badges/badges_table", event: @event, badges: @badges %>
  </div>
</div>
