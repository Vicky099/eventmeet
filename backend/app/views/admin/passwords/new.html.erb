<% content_for :page_title, "Forgot password" %>
<% content_for :auth_brand, Current.account&.name || "EventMeet" %>

<div class="text-center mt-2">
  <h5>Forgot your password?</h5>
  <p class="text-muted">We'll email you a link to reset it.</p>
</div>

<div class="p-2 mt-4">
  <%= form_for(resource, as: resource_name, url: password_path(resource_name), html: { method: :post }) do |f| %>
    <% if resource.errors.any? %>
      <div class="alert alert-danger" role="alert">
        <ul class="mb-0">
          <% resource.errors.full_messages.each do |message| %>
            <li><%= message %></li>
          <% end %>
        </ul>
      </div>
    <% end %>

    <div class="mb-3">
      <%= f.label :email, class: "form-label" %>
      <div class="position-relative input-custom-icon">
        <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "Enter email" %>
        <span class="bx bx-mail-send"></span>
      </div>
    </div>

    <div class="mt-3">
      <%= f.submit "Send reset instructions", class: "btn btn-primary w-100 waves-effect waves-light" %>
    </div>
  <% end %>

  <div class="mt-4 text-center">
    <%= link_to "Back to sign in", new_user_session_path, class: "fw-medium text-primary" %>
  </div>
</div>
