<% subtitle = @invoice.event ? @invoice.event.name : "Annual Contract" %>
<%= render "shared/mailer/heading", title: "Invoice ready", subtitle: subtitle %>

<div style="color:#686868;padding-top:16px;font-size:13px;line-height:1.6;">
  An invoice has been raised for <strong style="color:#1f1f1f;"><%= subtitle %></strong>.
</div>

<%= render "shared/mailer/details_table", rows: (
  if @invoice.event
    [ [ "Tenant", @invoice.account.name ], [ "Event", @invoice.event.name ], [ "Amount", money(@invoice.amount, @invoice.currency) ] ]
  else
    [ [ "Agency", @invoice.agency.name ], [ "Amount", money(@invoice.amount, @invoice.currency) ] ]
  end
) %>

<div style="color:#686868;padding-bottom:4px;font-size:13px;line-height:1.6;">
  Please pay via bank transfer (NEFT/IMPS) and submit the UTR/receipt as proof of payment.
</div>

<%= render "shared/mailer/button",
      url: agency_invoice_url(@invoice),
      label: "Review & Submit Payment →" %>
