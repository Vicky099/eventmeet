<%# Locals: result — ScanService::Result or nil (nothing scanned yet this page load).
    print_result — PrintTriggerService::Result or nil, present whenever a print was also
    attempted (Direction: Print only, or Direction: Check in/out with Also print on / the
    event's own auto_print_enabled toggle, Phase 10 revisit — requirement.md §5.5.1). Mirrors
    admin/scan_events/_scan_result's own state handling (not_found/session_full/debounced/ok) but
    styled as a full-width banner with the participant's own photo when there is one — a kiosk
    operator matching a face to a badge is the whole point of a check-in desk, so surfacing it
    here (never shown on the admin dashboard's own recent-scans list) is worth the extra query. %>
<% if result.nil? %>
<% elsif result.not_found? %>
  <div class="checkin-result is-danger">
    <i class="bx bx-x-circle checkin-result-icon"></i>
    <div class="checkin-result-body">
      <strong>No match</strong>
      <span>No participant matches that identifier.</span>
    </div>
  </div>
<% elsif result.session_full? %>
  <div class="checkin-result is-danger">
    <i class="bx bx-block checkin-result-icon"></i>
    <div class="checkin-result-body">
      <strong><%= result.session.name %> is full</strong>
      <span><%= result.participant.name %> was not checked in — capacity (<%= result.session.seat_limit %>) reached.</span>
    </div>
  </div>
<% elsif result.debounced? %>
  <div class="checkin-result is-warning">
    <i class="bx bx-time-five checkin-result-icon"></i>
    <div class="checkin-result-body">
      <strong>Already scanned</strong>
      <span><%= result.participant.name %> was just scanned — ignoring this repeat within 30 seconds.</span>
    </div>
  </div>
<% elsif result.print_only? %>
  <%# Phase 10 revisit (requirement.md §5.5.1): "an option to only print badge and not mark the
      attendance check-in" — its own branch since there's no scan_event/session/redirect_url to
      read here, only whatever PrintTriggerService reported. %>
  <% if print_result.debounced? %>
    <div class="checkin-result is-warning">
      <i class="bx bx-time-five checkin-result-icon"></i>
      <div class="checkin-result-body">
        <strong>Already printed</strong>
        <span><%= result.participant.name %>'s badge was just printed — ignoring this repeat within 30 seconds.</span>
      </div>
    </div>
  <% elsif print_result.no_badge? %>
    <div class="checkin-result is-danger">
      <i class="bx bx-x-circle checkin-result-icon"></i>
      <div class="checkin-result-body">
        <strong>No badge designed</strong>
        <span>No badge has been designed for this event yet.</span>
      </div>
    </div>
  <% else %>
    <div class="checkin-result is-success">
      <%= render "participant_avatar", participant: result.participant %>
      <div class="checkin-result-body">
        <strong><%= result.participant.name %></strong>
        <span><%= render "print_status", print_result: print_result %></span>
      </div>
    </div>
  <% end %>
<% else %>
  <%# Check in stays the "good" green; check out is a distinct "leaving" state, not an error —
      the warning amber (already used for the debounce banner above) reads as "notable, not bad,"
      the right register for "this person just left." %>
  <div class="checkin-result <%= result.scan_event.check_out? ? "is-warning" : "is-success" %>">
    <%= render "participant_avatar", participant: result.participant %>
    <div class="checkin-result-body">
      <strong><%= result.participant.name %></strong>
      <span>
        <%= result.scan_event.scan_type.humanize %><%= " · #{result.session.name}" if result.session %>
        <% if result.participant.ticket_category %> · <%= result.participant.ticket_category.name %><% end %>
        · <%= result.scan_event.scanned_at.strftime("%H:%M:%S") %>
      </span>
      <%# Phase 10 revisit (requirement.md §5.5.1): "also print" outcome, shown alongside the
          check-in/out confirmation rather than replacing it — this scan still happened either way. %>
      <% if print_result %>
        <span class="d-block"><%= render "print_status", print_result: print_result %></span>
      <% end %>
      <% if result.redirect_url %>
        <%# requirement.md §3.7: "Virtual event redirect-on-check-in." %>
        <%= link_to "Open meeting link →", result.redirect_url, target: "_blank", rel: "noopener", class: "checkin-result-link" %>
      <% end %>
    </div>
    <%= link_to badge_admin_event_participant_path(@event, result.participant),
          class: "checkin-result-badge-btn", target: "_blank", rel: "noopener" do %>
      <i class="bx bx-id-card"></i> Badge
    <% end %>
  </div>
<% end %>
