<%# Phase 9 (requirement.md §5.15, §6 item 17). LiveDashboard.broadcast_platform_pulse replaces
    this exact node on every check-in/registration write against any currently-live event, across
    every tenant; SuperAdmin::DashboardController#index renders it directly for first paint.

    Locals: pulse — Hash from LiveDashboard.platform_pulse
      (:live_event_count, :registered_count, :checked_in_count, :occupancy_count) %>
<div id="platform-live-pulse">
  <%= render layout: "shared/card", locals: { title: "Cross-Tenant Live Pulse", icon: "bx-pulse" } do %>
    <% if pulse[:live_event_count].zero? %>
      <%= render "shared/empty_state", icon: "bx-pulse", message: "No events are currently live across any tenant." %>
    <% else %>
      <div class="row g-3">
        <div class="col-md-6 col-xl-3">
          <%= render "shared/stat_widget", label: "Live Events", value: pulse[:live_event_count], icon: "bx-broadcast", color: "primary" %>
        </div>
        <div class="col-md-6 col-xl-3">
          <%= render "shared/stat_widget", label: "Registered", value: pulse[:registered_count], icon: "bx-user-plus", color: "info" %>
        </div>
        <div class="col-md-6 col-xl-3">
          <%= render "shared/stat_widget", label: "Checked In", value: pulse[:checked_in_count], icon: "bx-log-in-circle", color: "success" %>
        </div>
        <div class="col-md-6 col-xl-3">
          <%= render "shared/stat_widget", label: "Currently In Venue", value: pulse[:occupancy_count], icon: "bx-walk", color: "warning" %>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
