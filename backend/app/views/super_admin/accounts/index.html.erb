<% content_for :page_title, "Tenants" %>

<%= render layout: "shared/page_header", locals: { icon: "bx-buildings", crumbs: [ { label: "Tenants" } ] } do %>
  <%= link_to "New Account", new_platform_account_path, class: "btn btn-sm btn-primary" %>
<% end %>

<div class="mb-3">
  <%= form_with url: platform_accounts_path, method: :get, local: true, class: "d-flex gap-2" do %>
    <%= text_field_tag :q, @query, class: "form-control", placeholder: "Search name or subdomain" %>
    <%# id: "status_filter", NOT the Rails-default id="status" — the vendored webadmin template's
        own app.min.css has a bare `#status { position: absolute; ... }` rule (a leftover demo
        status-dot style, unrelated to forms) that silently hijacks any element with that id.
        Same landmine class as any other bare id the template happens to also use — see
        app/assets/stylesheets/vendor/webadmin/css/app.min.css for the full list (#result,
        #input-number, #input-select are the other generic-looking ones to avoid). %>
    <%= select_tag :status,
          options_for_select([ [ "All statuses", "" ] ] + Account.statuses.keys.map { |s| [ s.humanize, s ] }, @status_filter),
          id: "status_filter", class: "form-select" %>
    <%= submit_tag "Search", class: "btn btn-sm btn-outline-secondary" %>
  <% end %>
</div>

<div class="card">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th>Name</th>
            <th>Subdomain</th>
            <th>Status</th>
            <th>Created</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @accounts.each do |account| %>
            <tr>
              <td><%= link_to account.name, platform_account_path(account) %></td>
              <td><%= account.subdomain_slug %></td>
              <td>
                <span class="badge <%= account.active? ? "bg-success" : "bg-secondary" %>"><%= account.status.humanize %></span>
              </td>
              <td><%= account.created_at.to_date.iso8601 %></td>
              <%# Icon, not a text button (ported from shopmate-backend's vendors/index.html.erb
                  Actions-column convention) — suspend/reinstate/edit live on the show page
                  (accounts/show.html.erb) now, not duplicated here. %>
              <td class="text-end">
                <%= link_to platform_account_path(account), class: "btn btn-sm btn-outline-primary", title: "View" do %>
                  <i class="bx bx-show"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @accounts.none? %>
            <tr><td colspan="5" class="text-center text-muted py-4">No tenants match.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
