<%# Locals: slug (String), availability (Symbol — :blank/:invalid/:reserved/:taken/:available).
    Rendered both as the AJAX response body for #check_slug (a matching <turbo-frame id="..."> is
    required for Turbo to know what to replace) and, implicitly, as an empty frame on first page
    load (the frame has no src until the user types — see slug_check_controller.js). %>
<%= turbo_frame_tag "slug_availability" do %>
  <% case availability %>
  <% when :invalid %>
    <small class="text-danger">3–63 chars, lowercase letters/numbers/hyphens, no leading/trailing hyphen.</small>
  <% when :reserved %>
    <small class="text-danger"><%= slug %> is a reserved word.</small>
  <% when :taken %>
    <small class="text-danger"><%= slug %> is already taken.</small>
  <% when :available %>
    <small class="text-success"><%= slug %>.<%= Rails.application.config.x.platform_domain %> is available.</small>
  <% end %>
<% end %>
