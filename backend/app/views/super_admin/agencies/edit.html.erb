<% content_for :page_title, "Edit #{@agency.name}" %>

<%= render "shared/page_header",
  icon: "bx-briefcase",
  crumbs: [
    { label: "Agencies", path: platform_agencies_path },
    { label: @agency.name, path: platform_agency_path(@agency) },
    { label: "Edit" }
  ] %>

<div class="row">
  <div class="col-xl-7 col-lg-9">
    <div class="card">
      <div class="card-body">
        <%= render "form", agency: @agency %>
      </div>
    </div>
  </div>
</div>
