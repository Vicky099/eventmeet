<% content_for :page_title, @event.name %>

<%= render "shared/page_header",
  icon: "bx-check-double",
  crumbs: [ { label: "Event Reviews", path: platform_event_reviews_path }, { label: @event.name } ] %>

<div class="row">
  <div class="col-lg-8">
    <div class="card mb-3">
      <div class="card-header bg-white">
        <h5 class="card-title mb-0">Event Details</h5>
      </div>
      <div class="card-body">
        <dl class="row mb-0">
          <dt class="col-sm-3">Tenant</dt>
          <dd class="col-sm-9"><%= @event.account.name %></dd>

          <dt class="col-sm-3">Name</dt>
          <dd class="col-sm-9"><%= @event.name %></dd>

          <dt class="col-sm-3">Mode</dt>
          <dd class="col-sm-9"><%= @event.mode.humanize %></dd>

          <dt class="col-sm-3">Schedule</dt>
          <dd class="col-sm-9"><%= @event.starts_at.to_fs(:long) %> &rarr; <%= @event.ends_at.to_fs(:long) %></dd>

          <dt class="col-sm-3">Location</dt>
          <dd class="col-sm-9">
            <% if @event.address.present? %><div><%= @event.address %></div><% end %>
            <% if @event.map_url.present? %><div><%= external_link_to "Map link", @event.map_url %></div><% end %>
            <% if @event.meeting_link.present? %><div><%= external_link_to @event.meeting_link, @event.meeting_link %></div><% end %>
            <% if @event.address.blank? && @event.meeting_link.blank? %><span class="text-muted">Not set</span><% end %>
          </dd>

          <dt class="col-sm-3">Status</dt>
          <dd class="col-sm-9"><span class="badge bg-info-subtle text-info"><%= @event.status.humanize %></span></dd>

          <dt class="col-sm-3">Submitted</dt>
          <dd class="col-sm-9 mb-0">
            <% if @event.submitted_at %>
              <%= time_ago_in_words(@event.submitted_at) %> ago
              <% if @event.review_sla_at_risk? %>
                <span class="badge bg-danger-subtle text-danger ms-1"><i class="bx bx-error-circle"></i> At risk (24h SLA)</span>
              <% end %>
            <% else %>
              <span class="text-muted">—</span>
            <% end %>
          </dd>
        </dl>
      </div>
    </div>

    <div class="card mb-3">
      <div class="card-header bg-white">
        <h5 class="card-title mb-0">Ticket Categories</h5>
      </div>
      <div class="card-body">
        <% if @event.ticket_categories.none? %>
          <p class="text-muted mb-0">None added yet.</p>
        <% else %>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead>
                <tr>
                  <th>Name</th>
                  <th>Total seats</th>
                  <th>Sold</th>
                  <th>Remaining</th>
                  <th>Document required</th>
                </tr>
              </thead>
              <tbody>
                <% @event.ticket_categories.each do |category| %>
                  <tr>
                    <td><%= category.name %></td>
                    <td><%= category.total_count || "Unlimited" %></td>
                    <td><%= category.sold_count %></td>
                    <td><%= category.remain_count || "—" %></td>
                    <td><%= category.document_required? ? "Yes" : "No" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    </div>

    <%# Read-only list, not admin/badges/_badges_table's own preview/edit/copy/remove version —
        that partial's every action link (edit_admin_event_badge_path, preview_admin_event_badge_path,
        etc.) points at the tenant Admin Console, gated behind the :user Warden scope Super Admin
        sessions don't carry (a distinct :platform_staff scope, BaseController's own module
        comment) — none of those links would actually work from here. %>
    <div class="card mb-3">
      <div class="card-header bg-white">
        <h5 class="card-title mb-0">Badges</h5>
      </div>
      <div class="card-body">
        <% badges = @event.badges.includes(:ticket_category).order(:ticket_category_id) %>
        <% if badges.none? %>
          <p class="text-muted mb-0">No badges designed yet.</p>
        <% else %>
          <div class="table-responsive">
            <table class="table table-sm align-middle mb-0">
              <thead>
                <tr>
                  <th>Badge</th>
                  <th>Applies to</th>
                  <th>Type</th>
                  <th>Size (cm)</th>
                  <th>Background</th>
                  <th>Logo</th>
                </tr>
              </thead>
              <tbody>
                <% badges.each do |badge| %>
                  <tr>
                    <td><%= badge.name %></td>
                    <td><%= badge.ticket_category&.name || "Default (every other participant)" %></td>
                    <td><%= badge.output_type.humanize %></td>
                    <td><%= badge.width_cm %> &times; <%= badge.height_cm %></td>
                    <td><%= badge.background_image.attached? ? "Yes" : "—" %></td>
                    <td><%= badge.logo.attached? ? "Yes" : "—" %></td>
                  </tr>
                <% end %>
              </tbody>
            </table>
          </div>
        <% end %>
      </div>
    </div>

    <%# Same two-cards-in-a-row shape as admin/events/_review_step.html.erb's own Speakers/Agenda
        section — read-only detail, not just a count, for the same "approve based on what's
        actually there" reasoning as every section above. %>
    <% speakers = @event.speakers.order(:name)
       sessions = @event.sessions.includes(schedules: :speaker).order(:starts_at)
       days = sessions.group_by { |session| session.starts_at.to_date }
       unscheduled_talks = @event.schedules.where(session_id: nil).includes(:speaker).order(:starts_at) %>
    <div class="row g-3 mb-3">
      <div class="col-md-6">
        <div class="card h-100 mb-0">
          <div class="card-header bg-white">
            <h5 class="card-title mb-0">Speakers</h5>
          </div>
          <div class="card-body">
            <% if speakers.none? %>
              <p class="text-muted mb-0">No speakers added yet.</p>
            <% else %>
              <div class="table-responsive">
                <table class="table table-sm align-middle mb-0">
                  <thead>
                    <tr>
                      <th></th>
                      <th>Name</th>
                      <th>Company</th>
                      <th>Contact</th>
                    </tr>
                  </thead>
                  <tbody>
                    <% speakers.each do |speaker| %>
                      <tr>
                        <td>
                          <% if speaker.photo.attached? %>
                            <%# Not image_tag(attachment) — 500s the moment it's exercised
                                against a real attached photo ("no implicit conversion of
                                ActiveStorage::Attached::One into String"), compounded by this
                                app's config/cloudinary.yml `enhance_image_tag: true` mangling any
                                URL string fed to image_tag instead (see
                                checkin/_result.html.erb's own comment, where this was first
                                caught live). A bare <img> via `tag.img` sidesteps image_tag
                                entirely. %>
                            <%= tag.img src: speaker.photo.url, class: "rounded-circle", style: "width: 28px; height: 28px; object-fit: cover;" %>
                          <% else %>
                            <i class="bx bx-user-circle font-size-20 text-muted"></i>
                          <% end %>
                        </td>
                        <td><%= speaker.name %></td>
                        <td><%= speaker.company.presence || "—" %></td>
                        <td><%= [ speaker.email, speaker.contact_num ].compact_blank.join(" · ").presence || "—" %></td>
                      </tr>
                    <% end %>
                  </tbody>
                </table>
              </div>
            <% end %>
          </div>
        </div>
      </div>

      <div class="col-md-6">
        <div class="card h-100 mb-0">
          <div class="card-header bg-white">
            <h5 class="card-title mb-0">Agenda</h5>
          </div>
          <div class="card-body">
            <% if days.empty? && unscheduled_talks.none? %>
              <p class="text-muted mb-0">No sessions or talks scheduled yet.</p>
            <% else %>
              <% days.sort.each do |day, sessions_for_day| %>
                <h6 class="text-muted font-size-12 fw-normal mb-2"><%= day.strftime("%A, %B %-d") %></h6>
                <% sessions_for_day.sort_by(&:starts_at).each do |session| %>
                  <div class="border rounded p-2 mb-2">
                    <div class="fw-semibold font-size-13">
                      <%= session.name %>
                      <span class="text-muted font-size-12 fw-normal">
                        (<%= session.starts_at.strftime("%H:%M") %>&ndash;<%= session.ends_at.strftime("%H:%M") %><%
                          %><%= ", #{session.track}" if session.track.present? %><%= ", #{session.room}" if session.room.present? %>)
                      </span>
                    </div>
                    <% if session.schedules.any? %>
                      <ul class="list-unstyled mt-2 mb-0 font-size-13">
                        <% session.schedules.sort_by(&:starts_at).each do |schedule| %>
                          <li><%= schedule.title %> &mdash; <%= schedule.speaker.name %> (<%= schedule.starts_at.strftime("%H:%M") %>)</li>
                        <% end %>
                      </ul>
                    <% end %>
                  </div>
                <% end %>
              <% end %>

              <% if unscheduled_talks.any? %>
                <h6 class="text-muted font-size-12 fw-normal mt-3 mb-2">Other Talks (no session)</h6>
                <% unscheduled_talks.each do |schedule| %>
                  <div class="border rounded p-2 mb-2 font-size-13">
                    <%= schedule.title %> &mdash; <%= schedule.speaker.name %> (<%= schedule.starts_at.strftime("%b %-d, %H:%M") %>)
                  </div>
                <% end %>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <%# Sticky — the left column got a lot longer once it grew from one summary card into the full
      event detail (Ticket Categories/Badges/Speakers/Agenda below), and the decision itself is
      the one thing on this page that should stay reachable while scrolling through all of it. %>
  <div class="col-lg-4">
    <div class="card" style="position: sticky; top: 1rem;">
      <div class="card-header bg-white">
        <h5 class="card-title mb-0">Review Decision</h5>
      </div>
      <div class="card-body">
        <%= button_to "Approve", approve_platform_event_review_path(@event), method: :post,
              class: "btn btn-sm btn-success w-100 mb-3",
              data: { action: "click->confirm-dialog#show", title: "Approve Event", message: "Approve \"#{@event.name}\"? It becomes visible on the public site once approved." } %>

        <hr>

        <%= form_with url: reject_platform_event_review_path(@event), method: :post, local: true do |f| %>
          <div class="mb-2">
            <%= label_tag :rejection_reason, "Rejection reason", class: "form-label" %>
            <%= text_area_tag :rejection_reason, nil, class: "form-control", rows: 4, placeholder: "Required — the organizer sees this." %>
          </div>
          <%= f.submit "Reject", class: "btn btn-sm btn-outline-danger w-100",
                data: { action: "click->confirm-dialog#show", title: "Reject Event", message: "Reject \"#{@event.name}\"? The organizer is notified by email with your reason.", danger: "true" } %>
        <% end %>
      </div>
    </div>
  </div>
</div>
