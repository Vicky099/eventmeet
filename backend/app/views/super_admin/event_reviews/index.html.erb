<% content_for :page_title, "Event Reviews" %>

<%= render "shared/page_header", icon: "bx-check-double", crumbs: [ { label: "Event Reviews" } ] %>

<div class="card">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th>Event</th>
            <th>Tenant</th>
            <th>Submitted</th>
            <th>SLA</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @events.each do |event| %>
            <tr>
              <td><%= link_to event.name, platform_event_review_path(event) %></td>
              <td><%= event.account.name %></td>
              <td><%= event.submitted_at ? time_ago_in_words(event.submitted_at) + " ago" : "—" %></td>
              <td>
                <% if event.review_sla_at_risk? %>
                  <span class="badge bg-danger-subtle text-danger"><i class="bx bx-error-circle"></i> At risk</span>
                <% else %>
                  <span class="badge bg-success-subtle text-success">On track</span>
                <% end %>
              </td>
              <td class="text-end">
                <%= link_to platform_event_review_path(event), class: "btn btn-sm btn-outline-primary", title: "Review" do %>
                  <i class="bx bx-show"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @events.none? %>
            <tr><td colspan="5" class="text-center text-muted py-4">No events awaiting review.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
