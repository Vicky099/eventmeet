<% content_for :page_title, "Super Admin sign in" %>
<% content_for :auth_brand, "EventMeet Platform" %>

<div class="text-center mt-2">
  <h5>Platform Console</h5>
  <p class="text-muted">Super Admin sign in.</p>
</div>

<div class="p-2 mt-4">
  <%# data-turbo="false" — see the equivalent comment in app/views/admin/sessions/new.html.erb. %>
  <%= form_for(resource, as: resource_name, url: session_path(resource_name), html: { data: { turbo: "false" } }) do |f| %>
    <div class="mb-3">
      <%= f.label :email, class: "form-label" %>
      <%= f.email_field :email, autofocus: true, autocomplete: "email", class: "form-control", placeholder: "Enter email" %>
    </div>

    <div class="mb-3">
      <%= f.label :password, class: "form-label" %>
      <%= render "shared/password_field", form: f, field: :password, placeholder: "Enter password", autocomplete: "current-password", autofocus: false %>
    </div>

    <% if devise_mapping.rememberable? %>
      <div class="form-check py-1">
        <%= f.check_box :remember_me, class: "form-check-input" %>
        <%= f.label :remember_me, class: "form-check-label" %>
      </div>
    <% end %>

    <div class="mt-3">
      <%= f.submit "Log In", class: "btn btn-primary w-100 waves-effect waves-light" %>
    </div>
  <% end %>
</div>
