<% content_for :page_title, "Invoices" %>

<%= render "shared/page_header", icon: "bx-credit-card", crumbs: [ { label: "Invoices" } ] %>

<div class="card">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th>Event</th>
            <th>Tenant</th>
            <th>Amount</th>
            <th>Status</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @invoices.each do |invoice| %>
            <tr>
              <td><%= invoice.event.name %></td>
              <td><%= invoice.account.name %></td>
              <td><%= money(invoice.amount, invoice.currency) %></td>
              <td>
                <% if invoice.paid? %>
                  <span class="badge bg-success-subtle text-success">Paid</span>
                <% elsif invoice.under_review? %>
                  <span class="badge bg-info-subtle text-info">Needs Verification</span>
                <% elsif invoice.awaiting_payment? %>
                  <span class="badge bg-warning-subtle text-warning">Awaiting Payment</span>
                <% else %>
                  <span class="badge bg-secondary-subtle text-secondary">Draft — not sent</span>
                <% end %>
              </td>
              <td class="text-end">
                <%= link_to platform_invoice_path(invoice), class: "btn btn-sm btn-outline-primary", title: "View" do %>
                  <i class="bx bx-show"></i>
                <% end %>
              </td>
            </tr>
          <% end %>
          <% if @invoices.none? %>
            <tr><td colspan="5" class="text-center text-muted py-4">No invoices yet.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>
