<%# Shared platform-mail callout box (ported from shopmate-backend's AgreementMailer "Security
    Notice" box) — used both for that same informational tone (:info, the default) and for
    surfacing a rejection reason (:danger). Locals: body (required, plain text — always rendered
    through ERB's normal output tag, so it stays auto-escaped; never marked html_safe here, since
    a rejection reason is admin-authored free text, not a literal this view controls), tone
    (optional, :info or :danger). %>
<% bg, fg = local_assigns[:tone] == :danger ? [ "#fdecea", "#c62828" ] : [ "#fff8e1", "#795548" ] %>
<table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-top:20px;">
  <tr>
    <td bgcolor="<%= bg %>" style="border-radius:4px;padding:14px 16px;font-size:13px;color:<%= fg %>;line-height:1.6;">
      <%= body %>
    </td>
  </tr>
</table>
