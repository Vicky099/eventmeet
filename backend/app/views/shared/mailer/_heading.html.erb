<%# Shared platform-mail heading (ported from shopmate-backend's own AgreementMailer email design
    — title, then a muted one-line subtitle underneath). Locals: title (required),
    subtitle (optional). Every platform mailer (account/agency/billing/event/report) composes its
    body from this + the other shared/mailer/_* partials, inside layouts/mailer.html.erb's outer
    card — ParticipantMailer is the one exception (tenant-branded, self-contained, `layout false`,
    see that mailer's own comment). %>
<div style="padding-top:32px;font-size:22px;font-weight:600;color:#1a237e;line-height:1.3;">
  <%= title %>
</div>
<% if local_assigns[:subtitle].present? %>
  <div style="color:#a6a6b1;font-size:13px;padding-top:4px;">
    <%= subtitle %>
  </div>
<% end %>
