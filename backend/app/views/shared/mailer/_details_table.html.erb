<%# Shared platform-mail key/value details block (ported from shopmate-backend's AgreementMailer
    "AGREEMENT DETAILS" table — bordered rows, label left/value right). Locals: rows — an Array of
    [label, value] pairs; a falsy row (e.g. `[["Most attended session", x] if x]`) is skipped, so
    callers can splat an optional row straight into the array instead of building it conditionally
    beforehand. %>
<table width="100%" border="0" cellpadding="0" cellspacing="0"
       style="border-top:1px solid #eeeeee;border-bottom:1px solid #eeeeee;margin:20px 0 24px;">
  <% rows.compact.each_with_index do |(label, value), index| %>
    <tr>
      <td style="padding:10px 0;font-size:13px;color:#8a8a8a;width:50%;<%= "border-top:1px solid #f5f5f5;" unless index.zero? %>">
        <%= label %>
      </td>
      <td style="padding:10px 0;font-size:13px;font-weight:600;color:#1f1f1f;text-align:right;<%= "border-top:1px solid #f5f5f5;" unless index.zero? %>">
        <%= value %>
      </td>
    </tr>
  <% end %>
</table>
