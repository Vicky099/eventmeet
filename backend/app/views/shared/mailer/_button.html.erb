<%# Shared platform-mail CTA button (ported from shopmate-backend's AgreementMailer design — a
    full-width, rounded, solid-color block link; table-cell-safe styling, all inline, no <style>
    block — the standard email-client-compatibility constraint every mailer view here follows).
    Locals: url (required), label (required). %>
<table role="presentation" width="100%" border="0" cellpadding="0" cellspacing="0" style="margin-top:8px;">
  <tr>
    <td align="center" bgcolor="#1a237e" style="border-radius:4px;">
      <a href="<%= url %>"
         style="display:block;padding:15px 0;font-size:14px;font-weight:600;color:#ffffff;text-decoration:none;text-align:center;">
        <%= label %>
      </a>
    </td>
  </tr>
</table>
