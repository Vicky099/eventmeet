<%# Shared Bootstrap confirm modal — ported from shopmate-backend's layouts/_confirm_dialog.html.erb
    (same template family) — rendered once per console (shared/_console_shell), driven by
    confirm_dialog_controller.js. Replaces the browser's native confirm() (data-turbo-confirm)
    for destructive actions, which can't be styled/branded and looks out of place next to the
    rest of the UI.

    Usage — on a submit button inside its own form (button_to or form_with + button):
      data-action="click->confirm-dialog#show"
      data-message="Suspend Acme Events? Its admin will no longer be able to log in."
      data-title="Suspend Account"   (optional, defaults to "Confirm")
      data-danger="true"             (optional, red confirm button instead of primary blue) %>
<div class="modal fade" id="confirmDialogModal" tabindex="-1" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content border-0 shadow">
      <div class="modal-header border-0 pb-0">
        <h5 class="modal-title fw-semibold" id="confirmDialogTitle">Confirm</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body pt-2 pb-1">
        <p class="text-muted font-size-14 mb-0" id="confirmDialogMessage">Are you sure?</p>
      </div>
      <div class="modal-footer border-0 pt-3">
        <button type="button" class="btn btn-secondary btn-m" data-bs-dismiss="modal">Cancel</button>
        <button type="button" class="btn btn-primary btn-m" id="confirmDialogOk">Confirm</button>
      </div>
    </div>
  </div>
</div>
