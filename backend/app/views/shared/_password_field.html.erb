<%# Locals: form (FormBuilder), field (Symbol, e.g. :password), placeholder (String),
    autocomplete (String), autofocus (Boolean).
    Wires up the eye show/hide toggle — see app/javascript/controllers/password_toggle_controller.js. %>
<div class="position-relative auth-pass-inputgroup input-custom-icon" data-controller="password-toggle">
  <%= form.password_field field, autofocus: autofocus, autocomplete: autocomplete, class: "form-control", placeholder: placeholder, data: { password_toggle_target: "input" } %>
  <button type="button" class="btn btn-link position-absolute h-100 end-0 top-0" data-action="password-toggle#toggle">
    <i class="mdi mdi-eye-outline font-size-18 text-muted" data-password-toggle-target="icon"></i>
  </button>
</div>
