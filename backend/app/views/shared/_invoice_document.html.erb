<%# The actual "looks like a proper invoice" document — plain inline styles (not Bootstrap
    classes/a <style> block) so this exact same partial renders identically embedded in a
    Bootstrap-chromed show page (no class/cascade collision with the rest of either console's own
    UI) and standalone inside InvoicePdfService's Grover render (pdf.html.erb), matching this
    app's own RegistrationPdfService/participant_mailer convention of inline-styled "branded
    document" HTML. Lives in shared/ (not super_admin/invoices/, where it started) — Invoices
    moved to the Agency Console entirely (requirement.md revisit), so both
    SuperAdmin::InvoicesController and AgencyConsole::InvoicesController render this exact same
    partial for their own #show/#download.

    The Platform itself is the issuer here (PlatformBankDetails), not the tenant's own logo —
    the tenant Account (or, fixed-hierarchy pivot, the Agency itself for an annual contract
    invoice) is the bill-to party, never the sender. %>
<% status_colors = {
     "draft" => { bg: "#f1f3f9", text: "#5b6b79" },
     "awaiting_payment" => { bg: "#fff3cd", text: "#8a6408" },
     "under_review" => { bg: "#cfe2ff", text: "#0a3679" },
     "paid" => { bg: "#d1f2e0", text: "#0f6848" }
   }
   status_color = status_colors.fetch(invoice.status) %>
<div style="background: #ffffff; border: 1px solid #e2e5ec; border-radius: 6px; padding: 32px; font-family: Helvetica, Arial, sans-serif; color: #32394e;">
  <table style="width: 100%; border-collapse: collapse; margin-bottom: 28px;">
    <tr>
      <td style="vertical-align: top;">
        <div style="font-size: 22px; font-weight: 700; letter-spacing: 0.5px; color: #1f58c7;">INVOICE</div>
        <div style="font-size: 13px; color: #74788d; margin-top: 4px;"><%= PlatformBankDetails::ACCOUNT_NAME %></div>
      </td>
      <td style="vertical-align: top; text-align: right;">
        <div style="font-size: 13px; color: #74788d;">Invoice #</div>
        <div style="font-size: 15px; font-weight: 600; margin-bottom: 8px;">INV-<%= invoice.id[0..7].upcase %></div>
        <span style="display: inline-block; padding: 4px 12px; border-radius: 12px; font-size: 12px; font-weight: 600; background: <%= status_color[:bg] %>; color: <%= status_color[:text] %>;">
          <%= invoice.status.humanize %>
        </span>
      </td>
    </tr>
  </table>

  <table style="width: 100%; border-collapse: collapse; margin-bottom: 28px;">
    <tr>
      <td style="width: 50%; vertical-align: top;">
        <% bill_to = invoice.account || invoice.agency %>
        <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: #74788d; margin-bottom: 6px;">Bill To</div>
        <div style="font-size: 14px; font-weight: 600;"><%= bill_to.name %></div>
        <% if bill_to.contact_email.present? %>
          <div style="font-size: 13px; color: #74788d;"><%= bill_to.contact_email %></div>
        <% end %>
        <% if bill_to.contact_num.present? %>
          <div style="font-size: 13px; color: #74788d;"><%= bill_to.contact_num %></div>
        <% end %>
      </td>
      <td style="width: 50%; vertical-align: top; text-align: right;">
        <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: #74788d; margin-bottom: 6px;">Invoice Date</div>
        <div style="font-size: 13px; margin-bottom: 10px;"><%= invoice.created_at.to_fs(:long) %></div>
        <% if invoice.sent_at.present? %>
          <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: #74788d; margin-bottom: 6px;">Sent</div>
          <div style="font-size: 13px;"><%= invoice.sent_at.to_fs(:long) %></div>
        <% end %>
      </td>
    </tr>
  </table>

  <table style="width: 100%; border-collapse: collapse; margin-bottom: 24px;">
    <thead>
      <tr>
        <th style="text-align: left; padding: 10px 0; border-bottom: 2px solid #32394e; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: #74788d;">Description</th>
        <th style="text-align: right; padding: 10px 0; border-bottom: 2px solid #32394e; font-size: 12px; text-transform: uppercase; letter-spacing: 0.5px; color: #74788d;">Amount</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td style="padding: 14px 0; border-bottom: 1px solid #e2e5ec; vertical-align: top;">
          <% if invoice.event %>
            <div style="font-size: 14px; font-weight: 600;"><%= invoice.event.name %></div>
            <div style="font-size: 12px; color: #74788d; margin-top: 2px;">
              <%= invoice.event.starts_at.to_fs(:long) %> &ndash; <%= invoice.event.ends_at.to_fs(:long) %>
            </div>
          <% else %>
            <div style="font-size: 14px; font-weight: 600;">Annual Contract — <%= invoice.agency.name %></div>
            <div style="font-size: 12px; color: #74788d; margin-top: 2px;">Unlimited events for one year</div>
          <% end %>
        </td>
        <td style="padding: 14px 0; border-bottom: 1px solid #e2e5ec; text-align: right; vertical-align: top; font-size: 14px;">
          <%= money(invoice.amount, invoice.currency) %>
        </td>
      </tr>
    </tbody>
    <tfoot>
      <tr>
        <td style="padding: 14px 0; text-align: right; font-size: 13px; color: #74788d;">Total</td>
        <td style="padding: 14px 0; text-align: right; font-size: 18px; font-weight: 700;"><%= money(invoice.amount, invoice.currency) %></td>
      </tr>
    </tfoot>
  </table>

  <% unless invoice.paid? %>
    <div style="background: #f8f9fc; border: 1px solid #e2e5ec; border-radius: 6px; padding: 16px 20px;">
      <div style="font-size: 11px; text-transform: uppercase; letter-spacing: 0.5px; color: #74788d; margin-bottom: 10px;">Payment Details (NEFT / IMPS)</div>
      <table style="width: 100%; border-collapse: collapse; font-size: 13px;">
        <tr>
          <td style="padding: 3px 0; color: #74788d; width: 40%;">Account Name</td>
          <td style="padding: 3px 0; font-weight: 600;"><%= PlatformBankDetails::ACCOUNT_NAME %></td>
        </tr>
        <tr>
          <td style="padding: 3px 0; color: #74788d;">Account Number</td>
          <td style="padding: 3px 0; font-weight: 600;"><%= PlatformBankDetails::ACCOUNT_NUMBER %></td>
        </tr>
        <tr>
          <td style="padding: 3px 0; color: #74788d;">IFSC Code</td>
          <td style="padding: 3px 0; font-weight: 600;"><%= PlatformBankDetails::IFSC_CODE %></td>
        </tr>
        <tr>
          <td style="padding: 3px 0; color: #74788d;">Bank &amp; Branch</td>
          <td style="padding: 3px 0; font-weight: 600;"><%= PlatformBankDetails::BANK_NAME %>, <%= PlatformBankDetails::BRANCH %></td>
        </tr>
      </table>
    </div>
  <% end %>

  <div style="margin-top: 24px; font-size: 12px; color: #a2a9bd; text-align: center;">
    This is a system-generated invoice from <%= PlatformBankDetails::ACCOUNT_NAME %>.
  </div>
</div>
