<!DOCTYPE html>
<html lang="en">
  <head>
    <%= render "shared/head" %>
  </head>

  <body>
    <%= render layout: "shared/console_shell", locals: {
      home_path: platform_staff_root_path,
      page_title_default: "Platform Console",
      nav_items: super_admin_nav_items,
      footer_text: "EventMeet Platform",
      user_dropdown: platform_staff_signed_in? ? {
        email: current_platform_staff.email,
        subtitle: "Super Admin",
        sign_out_path: destroy_platform_staff_session_path,
        avatar_bg_class: "bg-dark-subtle",
        avatar_text_class: "text-dark"
      } : nil
    } do %>
      <%= yield %>
    <% end %>
  </body>
</html>
