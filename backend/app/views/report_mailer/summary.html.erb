<%= render "shared/mailer/heading", title: "#{@event.scheduled_report_frequency.capitalize} report", subtitle: @event.name %>

<div style="color:#686868;padding-top:16px;font-size:13px;line-height:1.6;">
  Here's how <strong style="color:#1f1f1f;"><%= @event.name %></strong> is doing:
</div>

<%= render "shared/mailer/details_table", rows: [
  [ "Total registrations", @stats[:registered_count] ],
  [ "New since last report", @stats[:new_registrations] ],
  [ "Checked in", "#{@stats[:checked_in_count]} (#{@stats[:check_in_rate]}%)" ],
  [ "Currently in venue", @stats[:currently_in_venue_count] ],
  ([ "Most attended session", @stats[:top_session] ] if @stats[:top_session])
] %>

<%= render "shared/mailer/button", url: admin_event_url(@event), label: "View Live Dashboard →" %>
