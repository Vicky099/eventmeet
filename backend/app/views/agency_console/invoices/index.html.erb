<% content_for :page_title, "Invoices" %>

<%= render "shared/page_header", icon: "bx-credit-card", crumbs: [ { label: "Invoices" } ] %>

<div class="card">
  <div class="card-body">
    <div class="table-responsive">
      <table class="table table-hover align-middle mb-0">
        <thead>
          <tr>
            <th>Invoice</th>
            <th>Amount</th>
            <th>Status</th>
            <th class="text-end">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @invoices.each do |invoice| %>
            <tr>
              <td><%= invoice.event.present? ? "#{invoice.account.name} — #{invoice.event.name}" : "Annual Contract" %></td>
              <td><%= money(invoice.amount, invoice.currency) %></td>
              <td>
                <% if invoice.paid? %>
                  <span class="badge bg-success-subtle text-success">Paid</span>
                <% elsif invoice.under_review? %>
                  <span class="badge bg-info-subtle text-info">Under Review</span>
                <% elsif invoice.awaiting_payment? && invoice.rejection_reason.present? %>
                  <span class="badge bg-danger-subtle text-danger" title="<%= invoice.rejection_reason %>">Payment Rejected — resubmit</span>
                <% elsif invoice.awaiting_payment? %>
                  <span class="badge bg-warning-subtle text-warning">Awaiting Payment</span>
                <% else %>
                  <span class="badge bg-secondary-subtle text-secondary"><%= invoice.status.humanize %></span>
                <% end %>
              </td>
              <td class="text-end">
                <div class="d-flex justify-content-end gap-2">
                  <% if invoice.awaiting_payment? %>
                    <button type="button" class="btn btn-m btn-primary" data-bs-toggle="modal" data-bs-target="#mark-as-paid-<%= invoice.id %>">
                      Mark as Paid
                    </button>
                  <% end %>
                  <%= link_to agency_invoice_path(invoice), class: "btn btn-m btn-outline-primary", title: "View" do %>
                    <i class="bx bx-show"></i>
                  <% end %>
                </div>
              </td>
            </tr>
          <% end %>
          <% if @invoices.none? %>
            <tr><td colspan="4" class="text-center text-muted py-4">No invoices yet.</td></tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </div>
</div>

<% @invoices.select(&:awaiting_payment?).each do |invoice| %>
  <div class="modal fade" id="mark-as-paid-<%= invoice.id %>" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered">
      <div class="modal-content border-0 shadow">
        <%= form_with url: submit_payment_agency_invoice_path(invoice), method: :post, local: true, multipart: true do %>
          <div class="modal-header border-0 pb-0">
            <h5 class="modal-title fw-semibold">Mark as Paid — <%= invoice.event.present? ? invoice.event.name : "Annual Contract" %></h5>
            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
          </div>
          <div class="modal-body">
            <% if invoice.rejection_reason.present? %>
              <div class="alert alert-danger">
                Your previous submission was rejected: "<%= invoice.rejection_reason %>". Please resubmit.
              </div>
            <% end %>

            <p class="fw-semibold mb-1">Amount due: <%= money(invoice.amount, invoice.currency) %></p>

            <div class="border rounded p-2 mb-3 bg-light">
              <p class="text-muted font-size-12 mb-1">Pay via NEFT/IMPS to:</p>
              <dl class="row mb-0 font-size-13">
                <dt class="col-5">Account name</dt><dd class="col-7"><%= PlatformBankDetails::ACCOUNT_NAME %></dd>
                <dt class="col-5">Account number</dt><dd class="col-7"><%= PlatformBankDetails::ACCOUNT_NUMBER %></dd>
                <dt class="col-5">IFSC code</dt><dd class="col-7"><%= PlatformBankDetails::IFSC_CODE %></dd>
                <dt class="col-5">Bank</dt><dd class="col-7"><%= PlatformBankDetails::BANK_NAME %>, <%= PlatformBankDetails::BRANCH %></dd>
              </dl>
            </div>

            <div class="mb-3">
              <%= label_tag :utr_reference, "UTR / reference number", class: "form-label" %>
              <%= text_field_tag :utr_reference, nil, class: "form-control", required: true %>
            </div>

            <%# Auto-uploads straight to Cloudinary the same way Participant#photo/#document
                already do (real progress, no waiting for this modal's own Save) — was previously
                a plain relayed file_field_tag, the one upload on this form that didn't match
                their upload behavior. %>
            <div class="mb-3" data-controller="image-upload">
              <%= label_tag :receipt, "Transaction receipt (image or PDF)", class: "form-label" %>
              <%= file_field_tag :receipt, class: "form-control", accept: "image/*,application/pdf", name: nil,
                    data: { image_upload_target: "fileInput", action: "change->image-upload#fileSelected",
                            direct_upload_url: agency_direct_uploads_path(scope: { type: "invoice_receipt", invoice_id: invoice.id }),
                            blob_field_name: "receipt" } %>
              <%= render "shared/upload_progress", field_name: "receipt" %>
              <% if invoice.receipt.attached? %><small class="text-muted d-block">Current: <%= invoice.receipt.filename %></small><% end %>
            </div>
          </div>
          <div class="modal-footer border-0 pt-3">
            <button type="button" class="btn btn-outline-secondary btn-m" data-bs-dismiss="modal">Cancel</button>
            <button type="submit" class="btn btn-primary btn-m">Mark as Paid</button>
          </div>
        <% end %>
      </div>
    </div>
  </div>
<% end %>
