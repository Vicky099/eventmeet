# See https://help.github.com/articles/ignoring-files for more about ignoring files.
#
# Temporary files generated by your text editor or operating system
# belong in git's global ignore instead:
# `$XDG_CONFIG_HOME/git/ignore` or `~/.config/git/ignore`

# Ignore bundler config.
/.bundle

# Ignore all environment files.
/.env*

# Ignore all logfiles and tempfiles.
/log/*
/tmp/*
!/log/.keep
!/tmp/.keep

# Ignore pidfiles, but keep the directory.
/tmp/pids/*
!/tmp/pids/
!/tmp/pids/.keep

# Ignore storage (uploaded files in development and any SQLite databases).
/storage/*
!/storage/.keep
/tmp/storage/*
!/tmp/storage/
!/tmp/storage/.keep

/public/assets

# Ignore master key for decrypting credentials and more.
/config/master.key

/app/assets/builds/*
!/app/assets/builds/.keep

# Ignore Node packages (Playwright browser tooling only; app JS is served via importmap-rails).
/node_modules

# webadmin template reference pages (see vendor/webadmin_template/README.md) — dev-reference only,
# never served or imported by any code. Deliberately not committed (kept local-only rather than
# following requirement.md §5.14's "add it to the project workspace" verbatim) — get your own copy
# from wherever this one came from before working on an admin/platform screen.
/vendor/webadmin_template
